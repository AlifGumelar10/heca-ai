DB_PASSWORD=secret

# ---- ML Service (FastAPI) ----
ML_SERVICE_URL=http://localhost:8001
ML_SERVICE_TIMEOUT=30

# ---- Frontend (untuk CORS) ----
FRONTEND_URL=http://localhost:3000

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
