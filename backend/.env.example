APP_NAME="HeA AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ---- PostgreSQL ----
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
